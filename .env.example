# P402 Meter — Environment Variables
# Copy to .env.local and fill in values

# ── Required: AI ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=              # Gemini API key — get from Google AI Studio

# ── Required: Circle ──────────────────────────────────────────────────────────
CIRCLE_API_KEY=              # Circle developer API key
NANOPAYMENTS_API_BASE=https://gateway-api-testnet.circle.com

# ── Required: Database ────────────────────────────────────────────────────────
DATABASE_URL=                # PostgreSQL connection string (Neon recommended)

# ── Required: Auth ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=             # 32+ character random string
NEXTAUTH_URL=http://localhost:3000

# ── Optional: Demo mode ───────────────────────────────────────────────────────
# Set to "safe" to replay pre-recorded stream (no API keys needed for demo)
NEXT_PUBLIC_DEMO_MODE=       # leave blank for live mode, set "safe" for demo

# ── Optional: Arc onchain settlement ──────────────────────────────────────────
ARC_PRIVATE_KEY=             # Private key for Arc testnet wallet (escrow settlement)
ARC_RPC_URL=                 # Arc testnet RPC (defaults to public endpoint)
